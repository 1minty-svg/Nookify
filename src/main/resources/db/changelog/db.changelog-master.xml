<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="minty">
        <createTable tableName="furniture_models">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="model_path" type="VARCHAR(512)"/>
            <column name="width" type="DOUBLE PRECISION"/>
            <column name="height" type="DOUBLE PRECISION"/>
            <column name="depth" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <include file="db/changelog/db.changelog-1.1.xml"/>

</databaseChangeLog>